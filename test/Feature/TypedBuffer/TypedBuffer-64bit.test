#--- source.hlsl

// This test checks that we will get the expected values from invoking
// Load and Store methods on typed buffers `[RW]Buffer`.

// The expected behaviour is to load the values in at the given offset, 
// add them, and store the result at the respective offset in `Out`.

Buffer<int64_t> U0 : register(t0);
RWBuffer<int64_t> V0 : register(u1);
Buffer<int64_t2> U1 : register(t2);
RWBuffer<int64_t2> V1 : register(u3);
Buffer<uint64_t> U2 : register(t4);
RWBuffer<uint64_t> V2 : register(u5);
Buffer<uint64_t2> U3 : register(t6);
RWBuffer<uint64_t2> V3 : register(u7);

RWBuffer<int64_t> Out0 : register(u8);
RWBuffer<int64_t2> Out1 : register(u9);
RWBuffer<uint64_t> Out2 : register(u10);
RWBuffer<uint64_t2> Out3 : register(u11);

[numthreads(1,1,1)]
void main() {
  // int64_t
  Out0[0] = U0[0] + V0[0];
  Out0[1] = U0[1] + V0[1];
  Out0[2] = U0[2] + V0[2];

  // int64_t2
  Out1[0] = U1[0] + V1[0];
  Out1[1] = U1[1] + V1[1];
  Out1[2] = int64_t2(U1[2].x + V1[2].x, U1[2].y + V1[2].y);

  // uint64_t
  Out2[0] = U2[0] + V2[0];
  Out2[1] = U2[1] + V2[1];
  Out2[2] = U2[2] + V2[2];

  // uint64_t2
  Out3[0] = U3[0] + V3[0];
  Out3[1] = U3[1] + V3[1];
  Out3[2] = int64_t2(U3[2].x + V3[2].x, U3[2].y + V3[2].y);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [1, 1, 1]
Buffers:
  - Name: U0
    Format: Int64
    Channels: 1
    Data: [ -100, 200, -300 ]
  - Name: V0
    Format: Int64
    Channels: 1
    Data: [ 5, 6, -7 ]
  - Name: Out0
    Format: Int64
    Channels: 1
    FillSize: 24
  - Name: ExpectedOut0
    Format: Int64
    Channels: 1
    Data: [ -95, 206, -307 ]
  - Name: U1
    Format: Int64
    Channels: 2
    Data: [ -100, 200, -300, 400, -500, 600 ]
