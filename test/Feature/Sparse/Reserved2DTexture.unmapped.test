#--- source.hlsl
// Verifies the `TilesMapped: 0` knob on a sparse Texture2D suppresses tile
// mapping entirely. The texture resource is created and bound, but no heap
// tiles back it. We only confirm here that the create + bind plumbing tolerates
// a zero-tile mapping; we deliberately do NOT sample the unmapped tile because
// the read result is undefined on Tiled Resources Tier 1 hardware.
//
// To exercise something observable, the compute shader writes a known sentinel
// to every element of the output buffer without ever indexing the input
// texture. Successful execution proves we got past pipeline creation, resource
// binding, and dispatch.

Texture2D<float4> In : register(t0);
RWStructuredBuffer<float4> Out : register(u0);

[numthreads(8, 8, 1)]
void main(uint3 tid : SV_DispatchThreadID) {
  if (tid.x >= 64 || tid.y >= 64)
    return;
  Out[tid.y * 64 + tid.x] = float4(0.5, 0.5, 0.5, 0.5);
}

//--- pipeline.yaml
---
Shaders:
  - Stage: Compute
    Entry: main
DispatchParameters:
  DispatchGroupCount: [8, 8, 1]
Buffers:
  - Name: In
    Format: Float32
    Channels: 4
    FillSize: 65536
    FillValue: 0.0
    OutputProps:
      Height: 64
      Width: 64
      Depth: 1
  - Name: Out
    Format: Float32
    Channels: 4
    FillSize: 65536
  - Name: ExpectedOut
    Format: Float32
    Channels: 4
    FillSize: 65536
    FillValue: 0.5
Results:
  - Result: KernelRanCleanly
    Rule: BufferExact
    Actual: Out
    Expected: ExpectedOut
DescriptorSets:
  - Resources:
    - Name: In
      Kind: Texture2D
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
      IsReserved: True
      TilesMapped: 0
    - Name: Out
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# Same backend gating as the basic sparse-texture test.
# UNSUPPORTED: Vulkan, Metal
# XFAIL: Clang

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
