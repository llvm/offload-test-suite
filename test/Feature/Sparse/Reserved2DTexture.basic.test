#--- source.hlsl
// Smoke test for sparse / reserved Texture2D support.
//
// The input Texture2D is created as a sparse / reserved resource backed by an
// explicit tile heap (see `IsReserved: True` in the YAML below). For an RGBA32
// (128 bpp) texture the standard tile shape is 64x64 pixels and one tile
// occupies exactly 64KB, so a 64x64 texture uses exactly one tile. With
// `TilesMapped` unset, setupReservedResource defaults to "map every tile",
// so the entire texture is backed by heap memory and the upload that follows
// is well-defined for every texel.
//
// The compute shader streams each texel into a 1D RWStructuredBuffer indexed
// by (y * Width + x) so the readback can be a flat BufferExact comparison.

Texture2D<float4> In : register(t0);
RWStructuredBuffer<float4> Out : register(u0);

[numthreads(8, 8, 1)]
void main(uint3 tid : SV_DispatchThreadID) {
  if (tid.x >= 64 || tid.y >= 64)
    return;
  Out[tid.y * 64 + tid.x] = In[tid.xy];
}

//--- pipeline.yaml
---
Shaders:
  - Stage: Compute
    Entry: main
DispatchParameters:
  DispatchGroupCount: [8, 8, 1]
Buffers:
  - Name: In
    Format: Float32
    Channels: 4
    # 64x64 RGBA32 = exactly one standard 64KB tile.
    FillSize: 65536
    FillValue: 0.5
    OutputProps:
      Height: 64
      Width: 64
      Depth: 1
  - Name: Out
    Format: Float32
    Channels: 4
    FillSize: 65536
  - Name: ExpectedOut
    Format: Float32
    Channels: 4
    FillSize: 65536
    FillValue: 0.5
Results:
  - Result: SparseRoundTrip
    Rule: BufferExact
    Actual: Out
    Expected: ExpectedOut
DescriptorSets:
  - Resources:
    - Name: In
      Kind: Texture2D
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
      IsReserved: True
    - Name: Out
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# Sparse / reserved Texture2D support is a DirectX-only feature in the
# execution suite today; the VK backend has no equivalent wiring for tiled
# textures yet (#1050 tracks porting it). Metal is similarly unimplemented.
# UNSUPPORTED: Vulkan, Metal

# Clang's HLSL -> DXIL lowering does not yet implement Texture2D sampling /
# Load intrinsics needed for the compute path.
# XFAIL: Clang

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
