#--- source.hlsl
StructuredBuffer<uint4> In0 : register(t0);
StructuredBuffer<int4> In1 : register(t1);
StructuredBuffer<float4> In2 : register(t2);

RWStructuredBuffer<uint4> Out0 : register(u3);
RWStructuredBuffer<uint4> Out1 : register(u4);
RWStructuredBuffer<uint4> Out2 : register(u5);

[numthreads(1,1,1)]
void main() {
  // uint -> uint matrices (identity bit-cast)
  uint2x2 u22 = asuint(uint2x2(In0[0].xy, In0[0].zw));
  uint3x2 u32 = asuint(uint3x2(In0[1].xyz, In0[2].xyz));
  uint2x4 u24 = asuint(uint2x4(In0[3], In0[4]));
  uint4x4 u44 = asuint(uint4x4(In0[5], In0[6], In0[7], In0[8]));
  uint3x3 u33 = asuint(uint3x3(In0[9].xyz, In0[10].xyz, In0[11].xyz));
  uint4x3 u43 = asuint(uint4x3(In0[12].xyz, In0[13].xyz,
                               In0[14].xyz, In0[15].xyz));

  Out0[0] = uint4(u22[0], u22[1]);
  Out0[1] = uint4(u32[0], u32[1]);
  Out0[2] = uint4(u32[2], 0, 0);
  Out0[3] = u24[0];
  Out0[4] = u24[1];
  Out0[5] = u44[0];
  Out0[6] = u44[1];
  Out0[7] = u44[2];
  Out0[8] = u44[3];
  Out0[9]  = uint4(u33[0], 0);
  Out0[10] = uint4(u33[1], 0);
  Out0[11] = uint4(u33[2], 0);
  Out0[12] = uint4(u43[0], 0);
  Out0[13] = uint4(u43[1], 0);
  Out0[14] = uint4(u43[2], 0);
  Out0[15] = uint4(u43[3], 0);

  uint2x2 u22_const = asuint(uint2x2(0xffffffffu, 0u, 0x80000000u, 100u));
  Out0[16] = uint4(u22_const[0], u22_const[1]);

  // int -> uint matrices
  uint2x2 i22 = asuint(int2x2(In1[0].xy, In1[0].zw));
  uint3x2 i32 = asuint(int3x2(In1[1].xyz, In1[2].xyz));
  uint2x4 i24 = asuint(int2x4(In1[3], In1[4]));
  uint4x4 i44 = asuint(int4x4(In1[5], In1[6], In1[7], In1[8]));
  uint3x3 i33 = asuint(int3x3(In1[9].xyz, In1[10].xyz, In1[11].xyz));
  uint4x3 i43 = asuint(int4x3(In1[12].xyz, In1[13].xyz,
                              In1[14].xyz, In1[15].xyz));

  Out1[0] = uint4(i22[0], i22[1]);
  Out1[1] = uint4(i32[0], i32[1]);
  Out1[2] = uint4(i32[2], 0, 0);
  Out1[3] = i24[0];
  Out1[4] = i24[1];
  Out1[5] = i44[0];
  Out1[6] = i44[1];
  Out1[7] = i44[2];
  Out1[8] = i44[3];
  Out1[9]  = uint4(i33[0], 0);
  Out1[10] = uint4(i33[1], 0);
  Out1[11] = uint4(i33[2], 0);
  Out1[12] = uint4(i43[0], 0);
  Out1[13] = uint4(i43[1], 0);
  Out1[14] = uint4(i43[2], 0);
  Out1[15] = uint4(i43[3], 0);

  uint2x2 i22_const = asuint(int2x2(-1, 2, 0, 2147483647));
  Out1[16] = uint4(i22_const[0], i22_const[1]);

  // float -> uint matrices
  uint2x2 f22 = asuint(float2x2(In2[0].xy, In2[0].zw));
  uint3x2 f32 = asuint(float3x2(In2[1].xyz, In2[2].xyz));
  uint2x4 f24 = asuint(float2x4(In2[3], In2[4]));
  uint4x4 f44 = asuint(float4x4(In2[5], In2[6], In2[7], In2[8]));
  uint3x3 f33 = asuint(float3x3(In2[9].xyz, In2[10].xyz, In2[11].xyz));
  uint4x3 f43 = asuint(float4x3(In2[12].xyz, In2[13].xyz,
                                In2[14].xyz, In2[15].xyz));

  Out2[0] = uint4(f22[0], f22[1]);
  Out2[1] = uint4(f32[0], f32[1]);
  Out2[2] = uint4(f32[2], 0, 0);
  Out2[3] = f24[0];
  Out2[4] = f24[1];
  Out2[5] = f44[0];
  Out2[6] = f44[1];
  Out2[7] = f44[2];
  Out2[8] = f44[3];
  Out2[9]  = uint4(f33[0], 0);
  Out2[10] = uint4(f33[1], 0);
  Out2[11] = uint4(f33[2], 0);
  Out2[12] = uint4(f43[0], 0);
  Out2[13] = uint4(f43[1], 0);
  Out2[14] = uint4(f43[2], 0);
  Out2[15] = uint4(f43[3], 0);

  uint2x2 f22_const = asuint(float2x2(10.0, 0.0, 0.5, 1.0));
  Out2[16] = uint4(f22_const[0], f22_const[1]);
}
//--- pipeline.yaml

