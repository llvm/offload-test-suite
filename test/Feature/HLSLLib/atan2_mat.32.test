            10.0, -10.0, 5.0, 0.0 ]
  - Name: Out0
    Format: Float32
    Stride: 16
    FillSize: 256
  - Name: ExpectedOut0
    Format: Float32
    Stride: 16
    Data: [ 0.78540, 0.0, -2.35619, 1.57080,
            1.37340, 1.57080, -1.76819, 0.78540,
            1.55845, -2.35619, 0.0, 0.0,
            1.30496, 1.35632, 1.38246, 1.39827,
            0.78540, -0.78540, 0.0, 0.78540,
            0.78540, 0.0, -0.78540, 0.0,
            0.46365, 1.57080, 0.0, -1.57080,
            0.78540, 2.35619, -2.35619, -0.78540,
            -3.13909, -2.35619, -2.35619, -1.57017,
            0.78540, 0.0, -0.78540, 0.0,
            1.10715, -2.03444, 0.78540, 0.0,
            -2.35619, 0.78540, 0.64350, 0.0,
            0.78540, 0.78540, 0.78540, 0.0,
            -2.35619, -2.35619, -2.35619, 0.0,
            0.0, 1.57080, -0.78540, 0.0,
            0.78540, -2.35619, 0.78540, 0.0 ]
Results:
  - Result: Test0
    Rule: BufferFloatEpsilon
    Epsilon: 0.0008
    Actual: Out0
    Expected: ExpectedOut0
DescriptorSets:
  - Resources:
    - Name: In0
      Kind: StructuredBuffer
      DirectXBinding:
        Register: 0
