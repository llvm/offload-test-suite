#--- source.hlsl
StructuredBuffer<float4> In0 : register(t0);
StructuredBuffer<uint4> In1 : register(t1);
StructuredBuffer<int4> In2 : register(t2);

RWStructuredBuffer<float4> Out0 : register(u3);
RWStructuredBuffer<float4> Out1 : register(u4);
RWStructuredBuffer<float4> Out2 : register(u5);

[numthreads(1,1,1)]
void main() {
  // float -> float matrices (identity bit-cast)
  float2x2 f22 = asfloat(float2x2(In0[0].xy, In0[0].zw));
  float3x2 f32 = asfloat(float3x2(In0[1].xyz, In0[2].xyz));
  float2x4 f24 = asfloat(float2x4(In0[3], In0[4]));
  float4x4 f44 = asfloat(float4x4(In0[5], In0[6], In0[7], In0[8]));
  float3x3 f33 = asfloat(float3x3(In0[9].xyz, In0[10].xyz, In0[11].xyz));
  float4x3 f43 = asfloat(float4x3(In0[12].xyz, In0[13].xyz,
                                  In0[14].xyz, In0[15].xyz));

  Out0[0] = float4(f22[0], f22[1]);
  Out0[1] = float4(f32[0], f32[1]);
  Out0[2] = float4(f32[2], 0.0, 0.0);
  Out0[3] = f24[0];
  Out0[4] = f24[1];
  Out0[5] = f44[0];
  Out0[6] = f44[1];
  Out0[7] = f44[2];
  Out0[8] = f44[3];
  Out0[9]  = float4(f33[0], 0.0);
  Out0[10] = float4(f33[1], 0.0);
  Out0[11] = float4(f33[2], 0.0);
  Out0[12] = float4(f43[0], 0.0);
  Out0[13] = float4(f43[1], 0.0);
  Out0[14] = float4(f43[2], 0.0);
  Out0[15] = float4(f43[3], 0.0);

  float2x2 f22_const = asfloat(float2x2(0.0, 1.0, -1.0, 0.5));
  Out0[16] = float4(f22_const[0], f22_const[1]);

  float1x1 f11 = asfloat(float1x1(In0[0].x));
  Out0[17] = float4(f11[0], 0.0, 0.0, 0.0);

  float4x4 f44_const = asfloat(float4x4(0.0, 1.0, -1.0, 0.5,
                                        10.5, -10.5, 100.0, 0.0,
                                        1.0, 2.0, 3.0, 4.0,
                                        -1.0, -2.0, -3.0, -4.0));
  Out0[18] = f44_const[0];
  Out0[19] = f44_const[1];
  Out0[20] = f44_const[2];
  Out0[21] = f44_const[3];

  // uint -> float matrices
  float2x2 u22 = asfloat(uint2x2(In1[0].xy, In1[0].zw));
  float3x2 u32 = asfloat(uint3x2(In1[1].xyz, In1[2].xyz));
  float2x4 u24 = asfloat(uint2x4(In1[3], In1[4]));
  float4x4 u44 = asfloat(uint4x4(In1[5], In1[6], In1[7], In1[8]));
  float3x3 u33 = asfloat(uint3x3(In1[9].xyz, In1[10].xyz, In1[11].xyz));
  float4x3 u43 = asfloat(uint4x3(In1[12].xyz, In1[13].xyz,
                                 In1[14].xyz, In1[15].xyz));

  Out1[0] = float4(u22[0], u22[1]);
  Out1[1] = float4(u32[0], u32[1]);
  Out1[2] = float4(u32[2], 0.0, 0.0);
  Out1[3] = u24[0];
  Out1[4] = u24[1];
  Out1[5] = u44[0];
  Out1[6] = u44[1];
  Out1[7] = u44[2];
  Out1[8] = u44[3];
  Out1[9]  = float4(u33[0], 0.0);
  Out1[10] = float4(u33[1], 0.0);
  Out1[11] = float4(u33[2], 0.0);
  Out1[12] = float4(u43[0], 0.0);
  Out1[13] = float4(u43[1], 0.0);
  Out1[14] = float4(u43[2], 0.0);
  Out1[15] = float4(u43[3], 0.0);

  float2x2 u22_const = asfloat(uint2x2(0u, 1u, 10u, 100u));
  Out1[16] = float4(u22_const[0], u22_const[1]);

  float1x1 u11 = asfloat(uint1x1(In1[0].x));
  Out1[17] = float4(u11[0], 0.0, 0.0, 0.0);

  float4x4 u44_const = asfloat(uint4x4(0u, 1u, 10u, 100u,
                                       50u, 100u, 1000u, 0u,
                                       0u, 1u, 2u, 3u,
                                       10u, 20u, 30u, 40u));
  Out1[18] = u44_const[0];
  Out1[19] = u44_const[1];
  Out1[20] = u44_const[2];
  Out1[21] = u44_const[3];

  // int -> float matrices
  float2x2 i22 = asfloat(int2x2(In2[0].xy, In2[0].zw));
  float3x2 i32 = asfloat(int3x2(In2[1].xyz, In2[2].xyz));
  float2x4 i24 = asfloat(int2x4(In2[3], In2[4]));
  float4x4 i44 = asfloat(int4x4(In2[5], In2[6], In2[7], In2[8]));
  float3x3 i33 = asfloat(int3x3(In2[9].xyz, In2[10].xyz, In2[11].xyz));
  float4x3 i43 = asfloat(int4x3(In2[12].xyz, In2[13].xyz,
                                In2[14].xyz, In2[15].xyz));

  Out2[0] = float4(i22[0], i22[1]);
  Out2[1] = float4(i32[0], i32[1]);
  Out2[2] = float4(i32[2], 0.0, 0.0);
  Out2[3] = i24[0];
  Out2[4] = i24[1];
  Out2[5] = i44[0];
  Out2[6] = i44[1];
  Out2[7] = i44[2];
  Out2[8] = i44[3];
  Out2[9]  = float4(i33[0], 0.0);
  Out2[10] = float4(i33[1], 0.0);
  Out2[11] = float4(i33[2], 0.0);
  Out2[12] = float4(i43[0], 0.0);
  Out2[13] = float4(i43[1], 0.0);
  Out2[14] = float4(i43[2], 0.0);
  Out2[15] = float4(i43[3], 0.0);

  float2x2 i22_const = asfloat(int2x2(-1, 0, 50, 100));
  Out2[16] = float4(i22_const[0], i22_const[1]);

  float1x1 i11 = asfloat(int1x1(In2[0].x));
  Out2[17] = float4(i11[0], 0.0, 0.0, 0.0);

  float4x4 i44_const = asfloat(int4x4(-1, 0, 50, 100,
                                      1, 10, 100, 0,
                                      -1, 0, 1, 2,
                                      3, 10, 50, 100));
  Out2[18] = i44_const[0];
  Out2[19] = i44_const[1];
  Out2[20] = i44_const[2];
  Out2[21] = i44_const[3];
}
//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: In0
    Format: Float32
    Stride: 16
    Data: [ 0.0, 1.0, -1.0, 0.5,
            10.5, -10.5, 100.0, 0.0,
            -100.0, 0.001, -0.001, 0.0,
            1.0, 2.0, 3.0, 4.0,
            -1.0, -2.0, -3.0, -4.0,
            0.0, 1.0, -1.0, 0.5,
            -0.5, 10.0, -10.0, 100.0,
            -100.0, 0.001, -0.001, 1000.0,
            -1000.0, 99.99, -99.99, 50.5,
            0.0, 1.0, 2.0, 0.0,
            -1.0, -2.0, 0.25, 0.0,
            0.5, 0.75, 1.5, 0.0,
            1.0, 2.0, 3.0, 0.0,
            -1.0, -2.0, -3.0, 0.0,
            0.5, 1.5, 2.5, 0.0,
            10.0, 20.0, 30.0, 0.0 ]
