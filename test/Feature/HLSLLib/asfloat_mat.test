            50, 100, 1000, 0,
            10000, 202, 303, 0,
            0, 1, 50, 100,
            10, 1000, 10000, 100000,
            0, 1, 2, 3,
            10, 20, 30, 40,
            100, 200, 300, 400,
            1000, 2000, 3000, 4000,
            50, 100, 150, 0,
