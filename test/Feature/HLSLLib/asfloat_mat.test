            350, 400, 450, 0,
            10, 20, 30, 0,
            40, 50, 60, 0,
            100, 200, 300, 0,
            1000, 2000, 3000, 0 ]
  - Name: In2
    Format: Int32
    Stride: 16
    Data: [ -1, 0, 50, 100,
            1, 10, 100, 0,
            1000, 10000, 2147483647, 0,
            0, 50, 100, 1000,
            -1, 10, 2147483647, 100,
            -1, 0, 1, 2,
            3, 10, 50, 100,
            -1, -1, -1, -1,
            1000, 10000, -1, 2147483647,
            0, 50, 100, 0,
            -1, -1, 150, 0,
            200, -1, 2147483647, 0,
            -1, 0, 50, 0,
            -1, 100, -1, 0,
