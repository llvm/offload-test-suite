    Stride: 16
    Data: [ 0, 1.4013e-45, 1.4013e-44, 1.4013e-43,
            7.0065e-44, 1.4013e-43, 1.4013e-42, 1.4013e-41,
            2.8306e-43, 4.2459e-43, 0, 0,
