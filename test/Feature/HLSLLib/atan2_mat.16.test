            0xBC00, 0xC000, 0xC200, 0x0000,
            0x3C00, 0x0000, 0x3C00, 0x0000,
            0x4900, 0xC900, 0x4500, 0x0000 ]
    # 2x2: 1, 1, -1, 0
    # 3x2: 2, 0, -1, _, 1, 0.25, -1, _
