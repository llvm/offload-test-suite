#--- source.hlsl
StructuredBuffer<half4> In0 : register(t0);
StructuredBuffer<half4> In1 : register(t1);

RWStructuredBuffer<half4> Out0 : register(u2);

[numthreads(1,1,1)]
void main() {
  half2x2 r22 = atan2(half2x2(In0[0].xy, In0[0].zw),
                      half2x2(In1[0].xy, In1[0].zw));

  half3x2 r32 = atan2(half3x2(In0[1].xyz, In0[2].xyz),
                      half3x2(In1[1].xyz, In1[2].xyz));

  half2x4 r24 = atan2(half2x4(In0[3], In0[4]),
                      half2x4(In1[3], In1[4]));

  half4x4 r44 = atan2(half4x4(In0[5], In0[6], In0[7], In0[8]),
                      half4x4(In1[5], In1[6], In1[7], In1[8]));

  half3x3 r33 = atan2(half3x3(In0[9].xyz, In0[10].xyz, In0[11].xyz),
                      half3x3(In1[9].xyz, In1[10].xyz, In1[11].xyz));

  half4x3 r43 = atan2(half4x3(In0[12].xyz, In0[13].xyz, In0[14].xyz, In0[15].xyz),
                      half4x3(In1[12].xyz, In1[13].xyz, In1[14].xyz, In1[15].xyz));

  half2x2 r22_const = atan2(half2x2(1.0, 0.0, -1.0, 1.0),
                            half2x2(1.0, 1.0, -1.0, 0.0));

  Out0[0] = half4(r22[0], r22[1]);
  Out0[1] = half4(r32[0], r32[1]);
  Out0[2] = half4(r32[2], 0.0, 0.0);
  Out0[3] = r24[0];
  Out0[4] = r24[1];
  Out0[5] = r44[0];
  Out0[6] = r44[1];
  Out0[7] = r44[2];
  Out0[8] = r44[3];
  Out0[9]  = half4(r33[0], 0.0);
  Out0[10] = half4(r33[1], 0.0);
  Out0[11] = half4(r33[2], 0.0);
  Out0[12] = half4(r43[0], 0.0);
  Out0[13] = half4(r43[1], 0.0);
  Out0[14] = half4(r43[2], 0.0);
  Out0[15] = half4(r43[3], 0.0);
  Out0[16] = half4(r22_const[0], r22_const[1]);
}
//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: In0
    Format: Float16
    Stride: 8
    Data: [ 0x3C00, 0x0000, 0xBC00, 0x3C00,
            0x4900, 0x3C00, 0xC500, 0x0000,
            0x3C00, 0x4D10, 0xBC00, 0x0000,
            0x4D20, 0x4FA0, 0x5110, 0x5250,
            0x3C00, 0xBC00, 0x0000, 0x4000,
            0x3C00, 0x0000, 0xBC00, 0x0000,
            0x3800, 0x3C00, 0x0000, 0xBC00,
            0x3C00, 0x3C00, 0xBC00, 0xBC00,
            0xB400, 0xCD00, 0xCF80, 0xDE40,
            0x3C00, 0x0000, 0xBC00, 0x0000,
            0x4000, 0xC000, 0x3800, 0x0000,
            0xB800, 0x3E00, 0x4200, 0x0000,
            0x3C00, 0x4000, 0x4200, 0x0000,
