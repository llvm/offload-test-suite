    # 2x4: 1.30828, 1.36035, 1.38770, 1.40430, 0.78540, -0.78540, 0.0, 0.78540
    # 4x4: 0.78540, 0.0, -0.78540, 0.0, 0.46365, 1.57080, 0.0, -1.57080,
    #      0.78540, 2.35619, -2.35619, -0.78540, -3.13909, -2.35619, -2.35619, -1.57017
    # 3x3: 0.78540, 0.0, -0.78540, 1.10715, -2.03444, 0.78540, -2.35619, 0.78540, 0.64350
