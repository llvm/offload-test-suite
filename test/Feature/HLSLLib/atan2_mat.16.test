    Data: [ 0x3C00, 0x3C00, 0xBC00, 0x0000,
            0x4000, 0x0000, 0xBC00, 0x0000,
            0x3C00, 0x3400, 0xBC00, 0x0000,
            0x4580, 0x4680, 0x4780, 0x4840,
            0x3C00, 0x3C00, 0x3C00, 0x4000,
