#--- source.hlsl

struct CBVectors {
  float3 b1;
  int4 b2;
  uint2 b3;
  bool4 b4;
};

ConstantBuffer<CBVectors> CB : register(b0);
RWStructuredBuffer<CBVectors> Out : register(u1);

[numthreads(1,1,1)]
void main() {
  Out[0].b1 = CB.b1;
  Out[0].b2 = CB.b2;
  Out[0].b3 = CB.b3;
  Out[0].b4 = CB.b4;
}

//--- pipeline.yaml
---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: CB
    Format: Hex32
    Data: [
      0x3f800000, 0x40000000, 0x40400000, 0x5A5A5A5A,
      0x00000001, 0x00000002, 0x00000003, 0x00000004,
      0x00000001, 0x00000002, 0x5A5A5A5A, 0x5A5A5A5A,
      0x00000001, 0x00000000, 0x00000001, 0x00000000
    ]
  - Name: Out
    Format: Hex32
    Stride: 52
    FillSize: 52
  - Name: ExpectedOut
    Format: Hex32
    Data: [
      0x3f800000, 0x40000000, 0x40400000,
      0x00000001, 0x00000002, 0x00000003, 0x00000004,
      0x00000001, 0x00000002,
      0x00000001, 0x00000000, 0x00000001, 0x00000000
    ]
Results:
  - Result: Test
    Rule: BufferExact
    Actual: Out
    Expected: ExpectedOut
DescriptorSets:
  - Resources:
    - Name: CB
      Kind: ConstantBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: Out
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# RUN: split-file %s %t
# RUN: %dxc_target -fvk-use-dx-layout -T cs_6_5 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
