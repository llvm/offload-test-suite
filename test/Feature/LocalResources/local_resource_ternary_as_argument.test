#--- source.hlsl
// Test that a ternary picking between two globals, used directly as a
// call argument, reaches the callee with the per-`cond` global. With
// numthreads(1,1,1) tid.x is 0, so cond is false and Helper receives
// `gBuf1`.

RWByteAddressBuffer gBuf0 : register(u0);
RWByteAddressBuffer gBuf1 : register(u1);

void Helper(RWByteAddressBuffer buf, uint offset, uint value) {
    buf.Store(offset, value);
}

[numthreads(1,1,1)]
void main(uint3 tid : SV_DispatchThreadID) {
    bool cond = tid.x > 0;
    Helper(cond ? gBuf0 : gBuf1, tid.x * 4, 42);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [1, 1, 1]
Buffers:
  - Name: gBuf0
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: gBuf1
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedBuf0
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedBuf1
    Format: Int32
    Stride: 4
    Data: [42]
Results:
  - Result: Buf0Check
    Rule: BufferExact
    Actual: gBuf0
    Expected: ExpectedBuf0
  - Result: Buf1Check
    Rule: BufferExact
    Actual: gBuf1
    Expected: ExpectedBuf1
DescriptorSets:
  - Resources:
    - Name: gBuf0
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: gBuf1
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# Clang: silent at sema (warning does not fire for ternary at a call
# site); codegen error follows ("Resource access is not guaranteed to
# map to a unique global resource").
# XFAIL: Clang

# DXC: codegen error ("local resource not guaranteed to map to unique
# global resource").
# XFAIL: DXC

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
