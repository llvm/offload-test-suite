Results:
  - Result: Buf0Check
    Rule: BufferExact
    Actual: gBuf0
    Expected: ExpectedBuf0
  - Result: Buf1Check
    Rule: BufferExact
    Actual: gBuf1
    Expected: ExpectedBuf1
DescriptorSets:
  - Resources:
    - Name: gBuf0
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: gBuf1
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
