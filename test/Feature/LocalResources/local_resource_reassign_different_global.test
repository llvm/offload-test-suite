#--- source.hlsl
RWByteAddressBuffer gBuf0 : register(u0);
RWByteAddressBuffer gBuf1 : register(u1);

uint Pass_Reassign(uint idx) {
    RWByteAddressBuffer buf = gBuf0;
    buf.Store(idx * 4, 7);
    buf = gBuf1;
    buf.Store(idx * 4, 13);

    return 13;
}

[numthreads(8,8,1)]
void main(uint3 tid : SV_DispatchThreadID) {
    uint idx = tid.x + tid.y * 8;
    Pass_Reassign(idx);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: gBuf0
    Format: Int32
