#--- source.hlsl
// Reassign a local resource handle to a different global, then Store.
// Verifies last-write-wins semantics: the pre-reassignment Store writes
// to gBuf0, the post-reassignment Store writes to gBuf1, and both
// buffers end up populated with their respective sentinel values.

RWByteAddressBuffer gBuf0 : register(u0);
RWByteAddressBuffer gBuf1 : register(u1);

void Pass_Reassign(uint Idx) {
    RWByteAddressBuffer Buf = gBuf0;
    Buf.Store(Idx * 4, 7);
    Buf = gBuf1;
    Buf.Store(Idx * 4, 13);
}

[numthreads(8,8,1)]
void main(uint3 Tid : SV_DispatchThreadID) {
    uint Idx = Tid.x + Tid.y * 8;
    Pass_Reassign(Idx);
}

//--- pipeline.yaml

