#--- source.hlsl
// Test that a reassignment of a local resource *immediately before* a
// `break` is observed post-loop: the store after the loop should reach
// `gBuf1` (the value assigned just before break), not the initial
// binding to `gBuf0`.

RWByteAddressBuffer gBuf0 : register(u0);
RWByteAddressBuffer gBuf1 : register(u1);

[numthreads(1,1,1)]
void main(uint3 tid : SV_DispatchThreadID) {
    RWByteAddressBuffer buf = gBuf0;
    for (uint i = 0; i < 4; i++) {
        if (i == tid.x) {
            buf = gBuf1;
            break;
        }
    }
    buf.Store(tid.x * 4, 42);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: gBuf0
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: gBuf1
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedBuf0
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedBuf1
    Format: Int32
    Stride: 4
    Data: [42]
Results:
  - Result: Buf0Check
    Rule: BufferExact
    Actual: gBuf0
    Expected: ExpectedBuf0
  - Result: Buf1Check
    Rule: BufferExact
    Actual: gBuf1
    Expected: ExpectedBuf1
DescriptorSets:
  - Resources:
    - Name: gBuf0
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: gBuf1
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# Clang: codegen error after warning ("Resource access is not guaranteed
# to map to a unique global resource").
# XFAIL: Clang

# DXC: codegen error ("local resource not guaranteed to map to unique
# global resource").
# XFAIL: DXC

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
