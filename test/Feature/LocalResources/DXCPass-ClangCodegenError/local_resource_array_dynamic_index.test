#--- source.hlsl

// Test that a local resource array can be dynamically indexed at runtime.

RWByteAddressBuffer gBufArray[4] : register(u0);

[numthreads(1,1,1)]
void main(uint3 tid : SV_DispatchThreadID) {
    RWByteAddressBuffer arr[2];
    arr[0] = gBufArray[0];
    arr[1] = gBufArray[1];
    arr[tid.x & 1].Store(0, 42);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [1, 1, 1]
Buffers:
  - Name: gBufArray
    Format: Int32
    Stride: 4
    ArraySize: 4
    Data:
      - [0]
      - [0]
      - [0]
      - [0]
  - Name: ExpectedBuf0
    Format: Int32
    Stride: 4
    Data: [42]
  - Name: ExpectedBuf1
    Format: Int32
    Stride: 4
    Data: [0]
Results:
  - Result: Buf0Check
    Rule: BufferExact
    Actual: gBufArray[0]
    Expected: ExpectedBuf0
  - Result: Buf1Check
    Rule: BufferExact
    Actual: gBufArray[1]
    Expected: ExpectedBuf1
DescriptorSets:
  - Resources:
    - Name: gBufArray
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
...
#--- end

# Bug: TODO - Clang DXIL Legalizer assertion failure on dynamically-indexed local resource arrays
# XFAIL: Clang

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
