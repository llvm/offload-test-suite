#--- source.hlsl
// Test that a helper returning one of two globals on different paths
// produces a binding-ambiguous result at the call site. With
// numthreads(1,1,1) tid.x is 0, so `Pick(tid.x > 0)` returns `g1`.

RWByteAddressBuffer g0 : register(u0);
RWByteAddressBuffer g1 : register(u1);

RWByteAddressBuffer Pick(bool c)
{
    if (c) return g0;
    return g1;
}

[numthreads(1,1,1)]
void main(uint3 tid : SV_DispatchThreadID)
{
    RWByteAddressBuffer buf = Pick(tid.x > 0);
    buf.Store(tid.x * 4, 42);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: g0
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: g1
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedG0
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedG1
    Format: Int32
    Stride: 4
    Data: [42]
Results:
  - Result: G0Check
    Rule: BufferExact
    Actual: g0
    Expected: ExpectedG0
  - Result: G1Check
    Rule: BufferExact
    Actual: g1
    Expected: ExpectedG1
DescriptorSets:
  - Resources:
    - Name: g0
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: g1
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# Clang: silent at sema (no warning fires for a call expression
# initializer); codegen error follows ("Resource access is not
# guaranteed to map to a unique global resource").
# XFAIL: Clang

# DXC: codegen error at the first `return` inside the helper.
# XFAIL: DXC

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
