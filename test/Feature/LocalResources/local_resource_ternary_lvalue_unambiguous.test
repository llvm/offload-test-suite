#--- source.hlsl
// Test that a ternary lvalue with a constant condition, used as the
// LHS of an assignment, resolves unambiguously after the backend
// folds the condition. `(true ? a : b) = gBuf0;` selects `a`, so
// `a.Store` reaches `gBuf0` and `b.Store` reaches `gBuf1`.

RWByteAddressBuffer gBuf0 : register(u0);
RWByteAddressBuffer gBuf1 : register(u1);

[numthreads(1,1,1)]
void main(uint3 tid : SV_DispatchThreadID) {
    RWByteAddressBuffer a = gBuf0;
    RWByteAddressBuffer b = gBuf1;
    (true ? a : b) = gBuf0;
    a.Store(tid.x * 4, 1);
    b.Store(tid.x * 4, 2);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: gBuf0
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: gBuf1
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedBuf0
    Format: Int32
    Stride: 4
    Data: [1]
  - Name: ExpectedBuf1
    Format: Int32
    Stride: 4
    Data: [2]
Results:
  - Result: Buf0Check
    Rule: BufferExact
    Actual: gBuf0
    Expected: ExpectedBuf0
  - Result: Buf1Check
    Rule: BufferExact
    Actual: gBuf1
    Expected: ExpectedBuf1
DescriptorSets:
  - Resources:
    - Name: gBuf0
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: gBuf1
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# Bug: https://github.com/llvm/llvm-project/issues/192523
# XFAIL: Clang && Vulkan

# Bug: https://github.com/microsoft/DirectXShaderCompiler/issues/8381
# XFAIL: DXC && Vulkan

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
