#--- source.hlsl
// Test that a local RWStructuredBuffer with subscript access works correctly.
RWStructuredBuffer<uint> gSB : register(u0);

[numthreads(1,1,1)]
void main() {
    RWStructuredBuffer<uint> sb = gSB;
    sb[0] = 42;
}
//--- pipeline.yaml
---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [1, 1, 1]
Buffers:
  - Name: gSB
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedGSB
    Format: Int32
    Stride: 4
    Data: [42]
Results:
  - Result: Test0
    Rule: BufferExact
    Actual: gSB
    Expected: ExpectedGSB
DescriptorSets:
  - Resources:
    - Name: gSB
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
...
#--- end

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
