#--- source.hlsl
RWByteAddressBuffer gBuf0 : register(u0);
RWByteAddressBuffer gBuf1 : register(u1);
RWByteAddressBuffer gBuf2 : register(u2);

uint Pass_Switch(int v, uint idx) {
    RWByteAddressBuffer buf = gBuf0;
    switch (v) {
        case 1: buf = gBuf1; break;
        case 2: buf = gBuf2; break;
    }
    buf.Store(idx * 4, 20);
    return 20;
}

[numthreads(8,8,1)]
void main(uint3 tid : SV_DispatchThreadID) {
    uint idx = tid.x + tid.y * 8;
    Pass_Switch(int(tid.x), idx);
}
//--- pipeline.yaml
---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [1, 1, 1]
Buffers:
  - Name: Out
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedOut
    Format: Int32
    Stride: 4
    Data: [20]
Results:
  - Result: Test0
    Rule: BufferExact
    Actual: Out
    Expected: ExpectedOut
DescriptorSets:
  - Resources:
    - Name: Out
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
...
#--- end

# Genuinely ambiguous: the switch condition is a runtime value, so `buf` may
# resolve to `gBuf0`, `gBuf1`, or `gBuf2` at the access site depending on `v`.
# DXC correctly errors at codegen. Clang emits the codegen error
# "Resource access is not guaranteed to map to a unique global resource"
# AND then ICEs in DXIL Op Lowering.
# XFAIL: *

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
