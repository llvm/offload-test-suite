#--- source.hlsl
// Test that both branches of an if/else assigning different elements of
// the same unbounded global resource array produce correct output.
// Two threads dispatch: thread 0 takes the `if` branch and writes to
// OutArr[0]; thread 1 takes the `else` branch and writes to OutArr[1].
// Each thread stores `In.Load(0) + Tid.x`, giving distinct values
// per destination so a bug that always took one branch would show up
// as an all-same-value pattern.
// NonUniformResourceIndex is required because the branch (and thus
// the chosen descriptor) is selected by Tid.x, which is wave-divergent.

RWByteAddressBuffer In : register(u0);
RWByteAddressBuffer OutArr[] : register(u1);

[numthreads(2,1,1)]
void main(uint3 Tid : SV_DispatchThreadID) {
    RWByteAddressBuffer Out;
    if (Tid.x == 0) {
        Out = OutArr[NonUniformResourceIndex(0)];
    } else {
        Out = OutArr[NonUniformResourceIndex(1)];
    }
    Out.Store(0, In.Load(0) + Tid.x);
}
//--- pipeline.yaml
---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: In
    Format: Int32
    Stride: 4
    Data: [42]
  - Name: OutArr
    Format: Int32
    Stride: 4
    ArraySize: 2
    Data:
      - [0]
      - [0]
  - Name: ExpectedOutArr
    Format: Int32
    Stride: 4
    ArraySize: 2
    Data:
      - [42]
      - [43]
Results:
  - Result: OutArrCheck
    Rule: BufferExact
    Actual: OutArr
    Expected: ExpectedOutArr
DescriptorSets:
  - Resources:
    - Name: In
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: OutArr
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# Bug: https://github.com/llvm/llvm-project/issues/192523
# XFAIL: Clang && Vulkan

# Bug: https://github.com/microsoft/DirectXShaderCompiler/issues/8581
# XFAIL: DXC && Vulkan

# Bug: https://github.com/llvm/offload-test-suite/issues/1375
# XFAIL: AMD && DXC && DirectX

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
