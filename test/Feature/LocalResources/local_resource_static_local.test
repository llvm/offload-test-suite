#--- source.hlsl
// Test that a `static` local resource initialized from a global binds
// once and persists across calls. Single-lane dispatch stores 1 at
// offset 0 of `gBuf0`.

RWByteAddressBuffer gBuf0 : register(u0);

uint Pass_StaticLocal(uint idx) {
    static RWByteAddressBuffer buf = gBuf0;
    buf.Store(idx * 4, 1);

    return 1;
}

[numthreads(1,1,1)]
void main(uint3 tid : SV_DispatchThreadID) {
    Pass_StaticLocal(tid.x);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: gBuf0
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedBuf0
    Format: Int32
    Stride: 4
    Data: [1]
Results:
  - Result: Buf0Check
    Rule: BufferExact
    Actual: gBuf0
    Expected: ExpectedBuf0
DescriptorSets:
  - Resources:
    - Name: gBuf0
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
...
#--- end

# Bug: https://github.com/llvm/llvm-project/issues/192523
# XFAIL: Clang && Vulkan

# Bug: https://github.com/microsoft/DirectXShaderCompiler/issues/8580
# XFAIL: DXC && D3D12

# Bug: https://github.com/llvm/llvm-project/issues/205169
# XFAIL: Clang

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
