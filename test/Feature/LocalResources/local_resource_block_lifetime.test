#--- source.hlsl

// Test that a local resource assigned inside a nested block scope
// remains valid after the block ends.

RWByteAddressBuffer Out : register(u0);

[numthreads(1,1,1)]
void main() {
    RWByteAddressBuffer buf;
    {
        buf = Out;
    }
    buf.Store(0, 42);
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [1, 1, 1]
Buffers:
  - Name: Out
    Format: Int32
    Stride: 4
    Data: [0]
  - Name: ExpectedOut
    Format: Int32
    Stride: 4
    Data: [42]
Results:
  - Result: Test0
    Rule: BufferExact
    Actual: Out
    Expected: ExpectedOut
DescriptorSets:
  - Resources:
    - Name: Out
      Kind: RWByteAddressBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
...
#--- end

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
