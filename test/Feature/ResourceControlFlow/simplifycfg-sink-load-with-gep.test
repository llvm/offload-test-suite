#--- source.hlsl

struct Foo {
  float A;
  float B;
};

RWStructuredBuffer<Foo>   BufA : register(u0);
RWStructuredBuffer<Foo>   BufB : register(u1);
RWStructuredBuffer<float> Out  : register(u2);

cbuffer Constants : register(b0) {
  uint Condition;
}

[numthreads(8, 1, 1)]
void main(uint TID : SV_DispatchThreadID) {
  if ((TID & 1u) == Condition) {
    Out[TID] = BufA[TID].B;
  } else {
    Out[TID] = BufB[TID].B;
  }
}

//--- pipeline.yaml
---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: Constants
    Format: Hex32
    Data: [ 0x00000000 ]

  - Name: BufA
    Format: Float32
    Stride: 8
    Data: [ 10, 110, 11, 111, 12, 112, 13, 113, 14, 114, 15, 115, 16, 116, 17, 117 ]

  - Name: BufB
    Format: Float32
    Stride: 8
    Data: [ 20, 210, 21, 211, 22, 212, 23, 213, 24, 214, 25, 215, 26, 216, 27, 217 ]

  - Name: BufOut
    Format: Float32
    FillSize: 32

  - Name: ExpectedOut
    Format: Float32
    Data: [ 110, 211, 112, 213, 114, 215, 116, 217 ]

Results:
  - Result: BufOut
    Rule: BufferFloatULP
    ULPT: 5
    Actual: BufOut
    Expected: ExpectedOut

DescriptorSets:
  - Resources:
    - Name: Constants
      Kind: ConstantBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: BufA
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 1
    - Name: BufB
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 2
    - Name: BufOut
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 2
        Space: 0
      VulkanBinding:
        Binding: 3
...
#--- end

# https://github.com/llvm/llvm-project/issues/207852
# XFAIL: Clang

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
