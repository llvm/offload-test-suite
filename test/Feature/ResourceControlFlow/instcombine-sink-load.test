#--- source.hlsl

// InstCombine sinks the two branch loads into the common successor, creating a
// phi of pointers into BufA/BufB (a resource).

[[vk::binding(1, 0)]] RWStructuredBuffer<uint> BufA : register(u0);
[[vk::binding(2, 0)]] RWStructuredBuffer<uint> BufB : register(u1);
[[vk::binding(3, 0)]] RWStructuredBuffer<uint> Out  : register(u2);

[[vk::binding(0, 0)]]
cbuffer Constants : register(b0) {
  uint Condition;
}

[numthreads(8, 1, 1)]
void main(uint TID : SV_DispatchThreadID) {
  uint Val;
  if ((TID & 1u) == Condition)
    Val = BufA[TID];
  else
    Val = BufB[TID];
  Out[TID] = Val;
}

//--- pipeline.yaml
---
Shaders:
  - Stage: Compute
    Entry: main
Buffers:
  - Name: Constants
    Format: Hex32
    Data: [ 0x00000000 ]

  - Name: BufA
    Format: UInt32
    Data: [ 10, 11, 12, 13, 14, 15, 16, 17 ]

  - Name: BufB
    Format: UInt32
    Data: [ 20, 21, 22, 23, 24, 25, 26, 27 ]

  - Name: BufOut
    Format: UInt32
    FillSize: 32

  - Name: ExpectedOut
    Format: UInt32
    Data: [ 10, 21, 12, 23, 14, 25, 16, 27 ]

Results:
  - Result: BufOut
    Rule: BufferExact
    Actual: BufOut
    Expected: ExpectedOut

DescriptorSets:
  - Resources:
    - Name: Constants
      Kind: ConstantBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: BufA
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 1
    - Name: BufB
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 2
    - Name: BufOut
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 2
        Space: 0
      VulkanBinding:
        Binding: 3
...
#--- end

# Bug: https://github.com/llvm/llvm-project/issues/207852
# XFAIL: Clang

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
