       4.5, 2.5, 0.0, 1.0,   5.5, 2.5, 0.0, 1.0,   6.5, 2.5, 0.0, 1.0,   7.5, 2.5, 0.0, 1.0,
       8.5, 2.5, 0.0, 1.0,   9.5, 2.5, 0.0, 1.0,  10.5, 2.5, 0.0, 1.0,  11.5, 2.5, 0.0, 1.0,
