# Bug: https://github.com/llvm/offload-test-suite/issues/986
# XFAIL: Intel && Vulkan && DXC

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_5 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o 
