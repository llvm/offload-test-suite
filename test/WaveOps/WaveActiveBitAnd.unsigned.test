# 64 bit wave ops are not supported on metal.
# https://github.com/llvm/offload-test-suite/issues/355
# UNSUPPORTED: Metal

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_5 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
