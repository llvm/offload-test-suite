#--- source.hlsl
StructuredBuffer<uint4> In  : register(t0);
StructuredBuffer<uint64_t4> In2 : register(t1);

RWStructuredBuffer<uint> Out1 : register(u1);
RWStructuredBuffer<uint2> Out2 : register(u2);
RWStructuredBuffer<uint4> Out3 : register(u3);
RWStructuredBuffer<uint4> Out4 : register(u4);

RWStructuredBuffer<uint64_t> Out5 : register(u5);
RWStructuredBuffer<uint64_t2> Out6 : register(u6);
RWStructuredBuffer<uint64_t4> Out7 : register(u7);
RWStructuredBuffer<uint64_t4> Out8 : register(u8);

RWStructuredBuffer<uint4> Out9 : register(u9);
RWStructuredBuffer<uint64_t4> Out10 : register(u10);

[numthreads(4,1,1)]
void main(uint3 tid : SV_GroupThreadID)
{
    uint4 v = In[tid.x];
    uint64_t4 v64 = In2[tid.x];

    Out1[tid.x] = WaveActiveBitAnd(v.x);

    Out2[tid.x] = WaveActiveBitAnd(v.xy);

    uint3 r3 = WaveActiveBitAnd(v.xyz);
    Out3[tid.x].xyz = r3;

    Out4[tid.x] = WaveActiveBitAnd(v);

    Out5[tid.x] = WaveActiveBitAnd(v64.x);

    Out6[tid.x] = WaveActiveBitAnd(v64.xy);

    uint64_t3 r64_3 = WaveActiveBitAnd(v64.xyz);
    Out7[tid.x].xyz = r64_3;

    Out8[tid.x] = WaveActiveBitAnd(v64);

    // constant folding uint4
    Out9[0] = WaveActiveBitAnd(uint4(1,2,3,4));
    Out10[0] = WaveActiveBitAnd(uint64_t4(1,2,3,4));
}

#--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [1,1,1]

Buffers:
  - Name: In
    Format: UInt32
    Stride: 16
