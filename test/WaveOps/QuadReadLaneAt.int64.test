# REQUIRES: Int64

# Currently not supported in Clang, ongoing PR
# XFAIL: Clang

# Bug: https://github.com/llvm/offload-test-suite/issues/959
# XFAIL: Metal

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_5 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
