#--- source.hlsl
StructuredBuffer<uint4> In  : register(t0);
StructuredBuffer<uint64_t4> In2 : register(t1);

RWStructuredBuffer<uint> Out1 : register(u1);
RWStructuredBuffer<uint2> Out2 : register(u2);
RWStructuredBuffer<uint4> Out3 : register(u3);
RWStructuredBuffer<uint4> Out4 : register(u4);

RWStructuredBuffer<uint64_t> Out5 : register(u5);
RWStructuredBuffer<uint64_t2> Out6 : register(u6);
RWStructuredBuffer<uint64_t4> Out7 : register(u7);
RWStructuredBuffer<uint64_t4> Out8 : register(u8);

RWStructuredBuffer<uint4> Out9 : register(u9);
RWStructuredBuffer<uint64_t4> Out10 : register(u10);

[numthreads(4,1,1)]
void main(uint3 tid : SV_GroupThreadID)
{
    uint4 v = In[tid.x];
    uint64_t4 v64 = In2[tid.x];

    Out1[tid.x] = WaveActiveBitXor(v.x);

    Out2[tid.x] = WaveActiveBitXor(v.xy);

    uint3 r3 = WaveActiveBitXor(v.xyz);
    Out3[tid.x].xyz = r3;

    Out4[tid.x] = WaveActiveBitXor(v);

    Out5[tid.x] = WaveActiveBitXor(v64.x);

    Out6[tid.x] = WaveActiveBitXor(v64.xy);

    uint64_t3 r64_3 = WaveActiveBitXor(v64.xyz);
    Out7[tid.x].xyz = r64_3;

    Out8[tid.x] = WaveActiveBitXor(v64);

    // constant folding uint4
    Out9[0] = WaveActiveBitXor(uint4(1,2,3,4));
    Out10[0] = WaveActiveBitXor(uint64_t4(1,2,3,4));
}

#--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [1,1,1]

Buffers:
  - Name: In
    Format: UInt32
    Stride: 16
    Data: [
      1,2,4,8,
      16,32,64,128,
      256,512,1024,2048,
      4096,8192,16384,32768
    ]
  - Name: In2
    Format: UInt64
    Stride: 32
    Data: [
      1,2,4,8,
      16,32,64,128,
      256,512,1024,2048,
      4096,8192,16384,32768
    ]
  - Name: Out1
    Format: UInt32
    Stride: 4
    FillSize: 16
  - Name: Out2
    Format: UInt32
    Stride: 8
    FillSize: 32
  - Name: Out3
    Format: UInt32
    Stride: 16
    FillSize: 64
  - Name: Out4
    Format: UInt32
    Stride: 16
    FillSize: 64
  - Name: Out5
    Format: UInt64
    Stride: 8
    FillSize: 32
  - Name: Out6
    Format: UInt64
    Stride: 16
    FillSize: 64
  - Name: Out7
    Format: UInt64
    Stride: 32
    FillSize: 128
  - Name: Out8
    Format: UInt64
    Stride: 32
    FillSize: 128
  - Name: Out9
    Format: UInt32
    Stride: 16
    FillSize: 16
  - Name: Out10
    Format: UInt64
    Stride: 32
    FillSize: 32

# Expected results
# XOR across lanes:
# lane values:
# 1 ^ 16 ^ 256 ^ 4096 = 4369
# 2 ^ 32 ^ 512 ^ 8192 = 8738
# 4 ^ 64 ^ 1024 ^ 16384 = 17476
# 8 ^ 128 ^ 2048 ^ 32768 = 34952

  - Name: ExpectedOut1
    Format: UInt32
    Stride: 4
    Data: [4369,4369,4369,4369]
  - Name: ExpectedOut2
    Format: UInt32
    Stride: 8
    Data: [
      4369,8738,
      4369,8738,
      4369,8738,
      4369,8738
    ]
  - Name: ExpectedOut3
    Format: UInt32
    Stride: 16
    Data: [
      4369,8738,17476,0,
      4369,8738,17476,0,
      4369,8738,17476,0,
      4369,8738,17476,0
    ]
  - Name: ExpectedOut4
    Format: UInt32
    Stride: 16
    Data: [
      4369,8738,17476,34952,
      4369,8738,17476,34952,
      4369,8738,17476,34952,
      4369,8738,17476,34952
    ]
  - Name: ExpectedOut5
    Format: UInt64
    Stride: 8
    Data: [4369,4369,4369,4369]
  - Name: ExpectedOut6
    Format: UInt64
    Stride: 16
    Data: [
      4369,8738,
      4369,8738,
      4369,8738,
      4369,8738
    ]
  - Name: ExpectedOut7
    Format: UInt64
    Stride: 32
    Data: [
      4369,8738,17476,0,
      4369,8738,17476,0,
      4369,8738,17476,0,
      4369,8738,17476,0
    ]
  - Name: ExpectedOut8
    Format: UInt64
    Stride: 32
    Data: [
      4369,8738,17476,34952,
      4369,8738,17476,34952,
      4369,8738,17476,34952,
      4369,8738,17476,34952
    ]
  - Name: ExpectedOut9
    Format: UInt32
    Stride: 16
    Data: [0, 0, 0, 0]
  - Name: ExpectedOut10
    Format: UInt64
    Stride: 32
    Data: [0, 0, 0, 0]

Results:
  - Result: ExpectedOut1
    Rule: BufferExact
    Actual: Out1
    Expected: ExpectedOut1
  - Result: ExpectedOut2
    Rule: BufferExact
    Actual: Out2
    Expected: ExpectedOut2
  - Result: ExpectedOut3
    Rule: BufferExact
    Actual: Out3
    Expected: ExpectedOut3
  - Result: ExpectedOut4
    Rule: BufferExact
    Actual: Out4
    Expected: ExpectedOut4
  - Result: ExpectedOut5
    Rule: BufferExact
    Actual: Out5
    Expected: ExpectedOut5
  - Result: ExpectedOut6
    Rule: BufferExact
    Actual: Out6
    Expected: ExpectedOut6
  - Result: ExpectedOut7
