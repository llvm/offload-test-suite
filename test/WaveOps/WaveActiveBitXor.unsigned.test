      VulkanBinding:
        Binding: 2
    - Name: Out2
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 2
        Space: 0
      VulkanBinding:
        Binding: 3
    - Name: Out3
      Kind: RWStructuredBuffer
      DirectXBinding:
