#--- source.hlsl
StructuredBuffer<float> In : register(t0);
RWStructuredBuffer<float> Out : register(u1);

[numthreads(2, 2, 1)]
void main(uint3 dtid : SV_DispatchThreadID) {
  uint index = dtid.y * 2 + dtid.x;
  float value = In[index];
  float value_quad_x = QuadReadAcrossX(value);
  float value_dx = value - value_quad_x;
  Out[index] = value_dx;
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [ 1, 1, 1 ]
Buffers:
  - Name: In
    Format: Float32
    Stride: 4
    Data: [ 1.0, 10.0, 2.0, 20.0 ]
  - Name: Out
    Format: Float32
    Stride: 4
    FillSize: 16
  - Name: ExpectedOut
    Format: Float32
    Stride: 4
    Data: [ -9.0, 9.0, -18.0, 18.0 ]
Results:
  - Result: ExpectedOut
    Rule: BufferExact
    Actual: Out
    Expected: ExpectedOut
DescriptorSets:
  - Resources:
    - Name: In
      Kind: StructuredBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
    - Name: Out
      Kind: RWStructuredBuffer
      DirectXBinding:
        Register: 1
        Space: 0
      VulkanBinding:
        Binding: 1
...
#--- end

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
