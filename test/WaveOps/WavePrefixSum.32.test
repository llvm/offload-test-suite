#--- source.hlsl
// ints
StructuredBuffer<int4> In  : register(t0);
RWStructuredBuffer<int4> Out1 : register(u1);
RWStructuredBuffer<int4> Out2 : register(u2);
RWStructuredBuffer<int4> Out3 : register(u3);
RWStructuredBuffer<int4> Out4 : register(u4);
RWStructuredBuffer<int4> Out5 : register(u5);

// uints
StructuredBuffer<uint4> UIn  : register(t6);
RWStructuredBuffer<uint4> UOut1 : register(u7);
RWStructuredBuffer<uint4> UOut2 : register(u8);
RWStructuredBuffer<uint4> UOut3 : register(u9);
RWStructuredBuffer<uint4> UOut4 : register(u10);
RWStructuredBuffer<uint4> UOut5 : register(u11);

// floats
StructuredBuffer<float4> FIn : register(t12);
RWStructuredBuffer<float4> FOut1 : register(u13);
RWStructuredBuffer<float4> FOut2 : register(u14);
RWStructuredBuffer<float4> FOut3 : register(u15);
RWStructuredBuffer<float4> FOut4 : register(u16);
RWStructuredBuffer<float4> FOut5 : register(u17);

[numthreads(4,1,1)]
void main(uint3 tid : SV_GroupThreadID)
{
    int4 v = In[0];

    // Mask per "active lane set": only <=N lanes contribute
    int s1 = tid.x <= 0 ? WavePrefixSum( v.x ) : 0;
    int s2 = tid.x <= 1 ? WavePrefixSum( v.x ) : 0;
    int s3 = tid.x <= 2 ? WavePrefixSum( v.x ) : 0;
    int s4 = tid.x <= 3 ? WavePrefixSum( v.x ) : 0;

    int2 v2_1 = tid.x <= 0 ? WavePrefixSum( v.xy ) : int2(0,0);
    int2 v2_2 = tid.x <= 1 ? WavePrefixSum( v.xy ) : int2(0,0);
    int2 v2_3 = tid.x <= 2 ? WavePrefixSum( v.xy ) : int2(0,0);
    int2 v2_4 = tid.x <= 3 ? WavePrefixSum( v.xy ) : int2(0,0);

    int3 v3_1 = tid.x <= 0 ? WavePrefixSum( v.xyz ) : int3(0,0,0);
    int3 v3_2 = tid.x <= 1 ? WavePrefixSum( v.xyz ) : int3(0,0,0);
    int3 v3_3 = tid.x <= 2 ? WavePrefixSum( v.xyz ) : int3(0,0,0);
    int3 v3_4 = tid.x <= 3 ? WavePrefixSum( v.xyz ) : int3(0,0,0);

    int4 v4_1 = tid.x <= 0 ? WavePrefixSum( v ) : int4(0,0,0,0);
    int4 v4_2 = tid.x <= 1 ? WavePrefixSum( v ) : int4(0,0,0,0);
    int4 v4_3 = tid.x <= 2 ? WavePrefixSum( v ) : int4(0,0,0,0);
    int4 v4_4 = tid.x <= 3 ? WavePrefixSum( v ) : int4(0,0,0,0);

    int scalars[4] = { s1, s2, s3, s4 };
    int2 vec2s [4] = { v2_1, v2_2, v2_3, v2_4 };
    int3 vec3s [4] = { v3_1, v3_2, v3_3, v3_4 };
    int4 vec4s [4] = { v4_1, v4_2, v4_3, v4_4 };

    Out1[tid.x].x   = scalars[tid.x];
    Out2[tid.x].xy  = vec2s[tid.x];
    Out3[tid.x].xyz = vec3s[tid.x];
    Out4[tid.x]     = vec4s[tid.x];
    Out5[tid.x]     = WavePrefixSum(int4(1,2,3,4));

    // UINT case

    uint4 uv = UIn[0];

    // Mask per "active lane set": only <=N lanes contribute
    uint us1 = tid.x <= 0 ? WavePrefixSum( uv.x ) : 0;
    uint us2 = tid.x <= 1 ? WavePrefixSum( uv.x ) : 0;
    uint us3 = tid.x <= 2 ? WavePrefixSum( uv.x ) : 0;
    uint us4 = tid.x <= 3 ? WavePrefixSum( uv.x ) : 0;

    uint2 uv2_1 = tid.x <= 0 ? WavePrefixSum( uv.xy ) : uint2(0,0);
    uint2 uv2_2 = tid.x <= 1 ? WavePrefixSum( uv.xy ) : uint2(0,0);
    uint2 uv2_3 = tid.x <= 2 ? WavePrefixSum( uv.xy ) : uint2(0,0);
    uint2 uv2_4 = tid.x <= 3 ? WavePrefixSum( uv.xy ) : uint2(0,0);

    uint3 uv3_1 = tid.x <= 0 ? WavePrefixSum( uv.xyz ) : uint3(0,0,0);
    uint3 uv3_2 = tid.x <= 1 ? WavePrefixSum( uv.xyz ) : uint3(0,0,0);
    uint3 uv3_3 = tid.x <= 2 ? WavePrefixSum( uv.xyz ) : uint3(0,0,0);
    uint3 uv3_4 = tid.x <= 3 ? WavePrefixSum( uv.xyz ) : uint3(0,0,0);

    uint4 uv4_1 = tid.x <= 0 ? WavePrefixSum( uv ) : uint4(0,0,0,0);
    uint4 uv4_2 = tid.x <= 1 ? WavePrefixSum( uv ) : uint4(0,0,0,0);
    uint4 uv4_3 = tid.x <= 2 ? WavePrefixSum( uv ) : uint4(0,0,0,0);
    uint4 uv4_4 = tid.x <= 3 ? WavePrefixSum( uv ) : uint4(0,0,0,0);

    uint uscalars[4] = { us1, us2, us3, us4 };
    uint2 uvec2s [4] = { uv2_1, uv2_2, uv2_3, uv2_4 };
    uint3 uvec3s [4] = { uv3_1, uv3_2, uv3_3, uv3_4 };
    uint4 uvec4s [4] = { uv4_1, uv4_2, uv4_3, uv4_4 };

    UOut1[tid.x].x   = uscalars[tid.x];
    UOut2[tid.x].xy  = uvec2s[tid.x];
    UOut3[tid.x].xyz = uvec3s[tid.x];
    UOut4[tid.x]     = uvec4s[tid.x];
    UOut5[tid.x]     = WavePrefixSum(uint4(1,2,3,4));

    // Float case

    float4 fv = FIn[0];

    // Mask per "active lane set": only <=N lanes contribute
    float fs1 = tid.x <= 0 ? WavePrefixSum( fv.x ) : 0;
    float fs2 = tid.x <= 1 ? WavePrefixSum( fv.x ) : 0;
    float fs3 = tid.x <= 2 ? WavePrefixSum( fv.x ) : 0;
    float fs4 = tid.x <= 3 ? WavePrefixSum( fv.x ) : 0;
    
    float2 fv2_1 = tid.x <= 0 ? WavePrefixSum( fv.xy ) : float2(0,0);
    float2 fv2_2 = tid.x <= 1 ? WavePrefixSum( fv.xy ) : float2(0,0);
    float2 fv2_3 = tid.x <= 2 ? WavePrefixSum( fv.xy ) : float2(0,0);
    float2 fv2_4 = tid.x <= 3 ? WavePrefixSum( fv.xy ) : float2(0,0);

    float3 fv3_1 = tid.x <= 0 ? WavePrefixSum( fv.xyz ) : float3(0,0,0);
    float3 fv3_2 = tid.x <= 1 ? WavePrefixSum( fv.xyz ) : float3(0,0,0);
    float3 fv3_3 = tid.x <= 2 ? WavePrefixSum( fv.xyz ) : float3(0,0,0);
    float3 fv3_4 = tid.x <= 3 ? WavePrefixSum( fv.xyz ) : float3(0,0,0);

    float4 fv4_1 = tid.x <= 0 ? WavePrefixSum( fv ) : float4(0,0,0,0);
    float4 fv4_2 = tid.x <= 1 ? WavePrefixSum( fv ) : float4(0,0,0,0);
    float4 fv4_3 = tid.x <= 2 ? WavePrefixSum( fv ) : float4(0,0,0,0);
    float4 fv4_4 = tid.x <= 3 ? WavePrefixSum( fv ) : float4(0,0,0,0);

    float fscalars[4] = { fs1, fs2, fs3, fs4 };
    float2 fvec2s [4] = { fv2_1, fv2_2, fv2_3, fv2_4 };
    float3 fvec3s [4] = { fv3_1, fv3_2, fv3_3, fv3_4 };
    float4 fvec4s [4] = { fv4_1, fv4_2, fv4_3, fv4_4 };

    FOut1[tid.x].x   = fscalars[tid.x];
    FOut2[tid.x].xy  = fvec2s[tid.x];
    FOut3[tid.x].xyz = fvec3s[tid.x];
    FOut4[tid.x]     = fvec4s[tid.x];
    FOut5[tid.x]     = WavePrefixSum(float4(1,2,3,4));
}

//--- pipeline.yaml

