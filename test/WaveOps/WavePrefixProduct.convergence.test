#--- source.hlsl
RWBuffer<int> value;

[numthreads(4, 1, 1)]
void main(uint3 threadID : SV_DispatchThreadID) {
  // Lane | switch status | WavePrefixProduct(2) | WavePrefixProduct(3) | Final
  // -----|---------------|----------------------|----------------------|------
  // 0    | active        | 1                    | 1                    | 1
  // 1    | active        | 1 * 2                | 1 * 3                | 2 * 3 = 6
  // 2    | inactive      | n/a                  | 1 * 3 * 3            | 1 * 9 = 9
  // 3    | inactive      | n/a                  | 1 * 3 * 3 * 3        | 1 * 27 = 27
  uint prod = 1;
  switch (value[threadID.x]) {
    case 0:
      prod *= WavePrefixProduct(2);
      break;
    default:
      break;
  }
  prod *= WavePrefixProduct(3);
  value[threadID.x] = prod;
}

//--- pipeline.yaml

---
Shaders:
  - Stage: Compute
    Entry: main
    DispatchSize: [ 1, 1, 1 ]
Buffers:
  - Name: value
    Format: Int32
    Data: [ 0, 0, 1, 2 ]
  - Name: Expected
    Format: Int32
    Data: [ 1, 6, 9, 27 ]
Results:
  - Result: Expected
    Rule: BufferExact
    Actual: value
    Expected: Expected
DescriptorSets:
  - Resources:
    - Name: value
      Kind: RWBuffer
      DirectXBinding:
        Register: 0
        Space: 0
      VulkanBinding:
        Binding: 0
...
#--- end

# RUN: split-file %s %t
# RUN: %dxc_target -T cs_6_0 -Fo %t.o %t/source.hlsl
# RUN: %offloader %t/pipeline.yaml %t.o
